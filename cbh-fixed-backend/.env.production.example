NODE_ENV=production
PORT=4000

# Shared Supabase (same as testing)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Production frontend origins (comma-separated)
ALLOWED_ORIGINS=https://your-production-frontend.vercel.app,https://yourdomain.com
ALLOW_TRYCLOUDFLARE_ORIGINS=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

ADMIN_EMAILS=admin@yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CBH Platform <your-email@gmail.com>"
CONTACT_EMAIL=admin@yourdomain.com

SUPABASE_STORAGE_BUCKET=business-assets
AVATAR_BUCKET=avatars
MAX_FILE_SIZE_MB=5

# Production frontend URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

NODE_ENV=production
PORT=4000

# Shared Supabase (same as production)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Testing frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-testing-frontend.vercel.app
# Enables any https://*.trycloudflare.com origin for local sharing
ALLOW_TRYCLOUDFLARE_ORIGINS=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

ADMIN_EMAILS=admin@yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CBH Platform <your-email@gmail.com>"
CONTACT_EMAIL=admin@yourdomain.com

SUPABASE_STORAGE_BUCKET=business-assets
AVATAR_BUCKET=avatars
MAX_FILE_SIZE_MB=5

# Testing frontend URL
NEXT_PUBLIC_SITE_URL=https://your-testing-frontend.vercel.app

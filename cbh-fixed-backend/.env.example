# ─────────────────────────────────────────────────────────────────────
# CBH Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Supabase ─────────────────────────────────────────────────────────
# From your Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Admin Access ─────────────────────────────────────────────────────
# Comma-separated email addresses that have admin access.
# These users will be redirected to /admin after login.
# To add/remove admins: edit this list and restart the server.
# Example: ADMIN_EMAILS=admin@yourdomain.com,ceo@yourdomain.com
ADMIN_EMAILS=admin@yourdomain.com

# ── Email (SMTP) ─────────────────────────────────────────────────────
# Used for feedback, message notifications, and admin “add business” invites
# (new owner accounts receive a generated password by email).
# Required for creating a brand-new auth user when the contact email has no profile yet.
# Leave blank to disable most emails (admin new-owner creation will return an error).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CBH Platform <your-email@gmail.com>"
CONTACT_EMAIL=admin@yourdomain.com

# ── Supabase Storage ─────────────────────────────────────────────────
# Bucket names — create these in Supabase Dashboard → Storage
SUPABASE_STORAGE_BUCKET=business-assets
AVATAR_BUCKET=avatars
MAX_FILE_SIZE_MB=5

# ── Site URL ─────────────────────────────────────────────────────────
# Used for generating links in emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000

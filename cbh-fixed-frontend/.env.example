# ─────────────────────────────────────────────────────────────────────
# CBH Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Supabase (from Dashboard → Settings → API) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API URL ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Admin Emails (must match ADMIN_EMAILS in backend .env) ───────────
# Comma-separated. Users with these emails are redirected to /admin after login.
NEXT_PUBLIC_ADMIN_EMAILS=admin@yourdomain.com

# ── Site URL (used for OG tags, links in emails, etc.) ───────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
